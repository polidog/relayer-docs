#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * relayer-doc CLI — edit articles directly in the store (Turso, or a
 * local SQLite file in development). The store is the single source of
 * truth; there are no Markdown source files.
 *
 * Usage:
 *   bin/docs migrate                 create the schema (idempotent)
 *   bin/docs list                    list articles
 *   bin/docs new  <slug>             create (opens $EDITOR)
 *   bin/docs edit <slug>             edit existing (opens $EDITOR)
 *   bin/docs show <slug>             print the stored article
 *   bin/docs rm   <slug> [--force]   delete
 *   bin/docs export <dir>            write every article as <slug>.md
 *   bin/docs import <file.md>...     upsert from front-matter Markdown
 *
 * new/edit accept `--file <path>` (`-` = stdin) for non-interactive use
 * and `--note <text>` to record what changed (auto-derived if omitted).
 *
 * Every command takes `--locale <code>` (default `ja`). `ja` is the
 * canonical page in `documents`; any other locale is a translation
 * overlay in `document_translations` that falls back to the canonical
 * page when absent. Allowed locales: ja, en.
 *
 * Backend (App\Docs\DocStoreFactory):
 *   TURSO_DATABASE_URL set  -> Turso (remote)   otherwise -> var/docs.db
 */

use App\AppConfigurator;
use App\Docs\DocRecord;
use App\Docs\DocStore;
use Symfony\Component\Config\FileLocator;
use Symfony\Component\DependencyInjection\ContainerBuilder;
use Symfony\Component\DependencyInjection\Loader\YamlFileLoader;
use Symfony\Component\Dotenv\Dotenv;
use Symfony\Component\Yaml\Yaml;

$root = \dirname(__DIR__);

require_once $root . '/vendor/autoload.php';

if (\is_file($root . '/.env')) {
    (new Dotenv())->loadEnv($root . '/.env');
}

$argv = $_SERVER['argv'] ?? [];
$command = $argv[1] ?? 'help';
$rest = \array_slice($argv, 2);

/** Pull `--flag` / `--flag=value` out of the argument list. */
$takeOpt = static function (array &$args, string $name): ?string {
    foreach ($args as $i => $arg) {
        if ($arg === '--' . $name) {
            $val = $args[$i + 1] ?? '';
            unset($args[$i], $args[$i + 1]);
            $args = \array_values($args);

            return $val;
        }
        if (\str_starts_with($arg, '--' . $name . '=')) {
            $val = \substr($arg, \strlen($name) + 3);
            unset($args[$i]);
            $args = \array_values($args);

            return $val;
        }
    }

    return null;
};
$hasFlag = static function (array &$args, string $name): bool {
    foreach ($args as $i => $arg) {
        if ($arg === '--' . $name) {
            unset($args[$i]);
            $args = \array_values($args);

            return true;
        }
    }

    return false;
};

// The CLI has no HTTP request, but it resolves DocStore through the
// same DI wiring the web app uses: AppConfigurator (the single
// composition root) reads the env vars into parameters and
// services.yaml injects them into DocStoreFactory. The factory itself
// stays env-free and web/CLI can never disagree on the backend.
$container = new ContainerBuilder();
$container->setParameter('app.project_root', $root);
(new AppConfigurator($root))->configure($container);
(new YamlFileLoader($container, new FileLocator($root . '/config')))->load('services.yaml');
$container->compile();

$store = $container->get(DocStore::class);
\assert($store instanceof DocStore);
$target = '' !== (string) $container->getParameter('app.turso_url')
    ? 'Turso (remote)'
    : 'var/docs.db (local)';

$fail = static function (string $msg): never {
    \fwrite(\STDERR, $msg . "\n");

    exit(1);
};

$assertSlug = static function (string $slug) use ($fail): void {
    if (!\preg_match('/^[a-z0-9][a-z0-9-]*$/', $slug)) {
        $fail("invalid slug '{$slug}' (use lower-case letters, digits, hyphen)");
    }
};

// Locales the store understands. `ja` is the canonical page in
// `documents`; anything else is an overlay in `document_translations`.
// Kept to the configured APP_LOCALES set so a typo can't silently
// create an orphan locale nobody routes to.
$locales = ['ja', 'en'];
$resolveLocale = static function (array &$args) use ($takeOpt, $fail, $locales): string {
    $locale = $takeOpt($args, 'locale') ?? 'ja';
    if (!\in_array($locale, $locales, true)) {
        $fail("unknown --locale '{$locale}' (allowed: " . \implode(', ', $locales) . ')');
    }

    return $locale;
};

/** DocRecord -> editable buffer (front matter + body). */
$serialize = static function (DocRecord $d): string {
    $fm = Yaml::dump([
        'title' => $d->title,
        'description' => $d->description,
        'category' => $d->category,
        'order' => $d->position,
    ], 2, 2);

    return "---\n" . $fm . "---\n\n" . \rtrim($d->content) . "\n";
};

/** Editable buffer + slug -> DocRecord (computes hash + timestamp). */
$deserialize = static function (string $buffer, string $slug) use ($fail): DocRecord {
    if (\preg_match('/^\xEF\xBB\xBF/', $buffer)) {
        $buffer = \substr($buffer, 3);
    }
    $meta = [];
    $body = $buffer;
    if (\preg_match('/^---\R(.*?)\R---\R?(.*)$/s', $buffer, $m)) {
        $parsed = Yaml::parse($m[1]);
        $meta = \is_array($parsed) ? $parsed : [];
        $body = $m[2];
    }

    $title = \trim((string) ($meta['title'] ?? ''));
    if ('' === $title && \preg_match('/^\#\s+(.+)$/m', $body, $h)) {
        $title = \trim($h[1]);
    }
    if ('' === $title) {
        $fail('title is required (front matter `title:` or a leading `# heading`)');
    }

    $description = (string) ($meta['description'] ?? '');
    $category = (string) ($meta['category'] ?? '');
    $position = (int) ($meta['order'] ?? $meta['position'] ?? 0);
    $body = \trim($body) . "\n";

    return new DocRecord(
        slug: $slug,
        title: $title,
        description: $description,
        category: $category,
        position: $position,
        content: $body,
        hash: DocRecord::hashOf($title, $description, $category, $position, $body),
        updatedAt: \gmdate('c'),
    );
};

/**
 * Open $EDITOR on $seed and return the edited text. Falls back to
 * --file/stdin when not attached to a terminal.
 */
$editBuffer = static function (string $seed, ?string $fileOpt) use ($fail): string {
    if (null !== $fileOpt) {
        $data = '-' === $fileOpt ? \stream_get_contents(\STDIN) : @\file_get_contents($fileOpt);
        if (!\is_string($data)) {
            $fail("cannot read --file '{$fileOpt}'");
        }

        return $data;
    }

    if (!\stream_isatty(\STDIN)) {
        $fail('no terminal for $EDITOR — pass --file <path> (or - for stdin)');
    }

    $tmp = \tempnam(\sys_get_temp_dir(), 'relayer-doc-') . '.md';
    \file_put_contents($tmp, $seed);

    $editor = \getenv('EDITOR') ?: (\getenv('VISUAL') ?: 'vi');
    $cmd = $editor . ' ' . \escapeshellarg($tmp);
    $tty = [['file', '/dev/tty', 'r'], ['file', '/dev/tty', 'w'], ['file', '/dev/tty', 'w']];
    $proc = \proc_open($cmd, $tty, $pipes);
    if (!\is_resource($proc)) {
        @\unlink($tmp);
        $fail("failed to launch editor: {$editor}");
    }
    \proc_close($proc);

    $edited = (string) \file_get_contents($tmp);
    @\unlink($tmp);

    return $edited;
};

switch ($command) {
    case 'migrate':
        $store->migrate();
        echo "migrated schema -> {$target}\n";

        break;

    case 'list':
        $store->migrate();
        $locale = $resolveLocale($rest);
        $rows = $store->nav();
        if ([] === $rows) {
            echo "no articles in {$target}. Create one: bin/docs new <slug>\n";

            break;
        }
        $translated = 'ja' === $locale ? [] : $store->translatedSlugs($locale);
        echo "articles in {$target} (locale: {$locale}):\n";
        $have = 0;
        foreach ($rows as $d) {
            $mark = 'ja' === $locale ? '' : (isset($translated[$d->slug]) ? '  ' : '* ');
            if ('' === $mark || '  ' === $mark) {
                ++$have;
            }
            \printf("  %s%-22s %-14s %s\n", $mark, $d->slug, $d->category, $d->title);
        }
        echo 'ja' === $locale
            ? \count($rows) . " total\n"
            : \count($rows) . " total, {$have} translated"
                . ' (* = falls back to ja)' . "\n";

        break;

    case 'show':
        $store->migrate();
        $locale = $resolveLocale($rest);
        $slug = $rest[0] ?? $fail('usage: bin/docs show <slug> [--locale <code>]');
        $doc = $store->get($slug, $locale) ?? $fail("not found: {$slug}");
        if ($locale !== $doc->locale) {
            \fwrite(\STDERR, "note: no '{$locale}' translation for '{$slug}' — showing {$doc->locale}\n");
        }
        echo $serialize($doc);

        break;

    case 'new':
    case 'edit':
        $store->migrate();
        $locale = $resolveLocale($rest);
        $fileOpt = $takeOpt($rest, 'file');
        $note = $takeOpt($rest, 'note');
        $slug = $rest[0] ?? $fail("usage: bin/docs {$command} <slug> [--locale <code>] [--file <path>|-] [--note <text>]");
        $assertSlug($slug);

        // `get($slug, $locale)` returns the canonical ja row as a
        // fallback when no translation exists, so the served record's
        // own `locale` is the exact "does a real <locale> row exist?"
        // signal — `=== $locale` only when one is actually stored.
        $served = $store->get($slug, $locale);
        $existsInLocale = null !== $served && $served->locale === $locale;

        if ('ja' === $locale) {
            if ('new' === $command && $existsInLocale) {
                $fail("already exists: {$slug} (use `bin/docs edit {$slug}`)");
            }
            if ('edit' === $command && !$existsInLocale) {
                $fail("not found: {$slug} (use `bin/docs new {$slug}`)");
            }
            $seed = $existsInLocale
                ? $serialize($served)
                : "---\ntitle: ''\ndescription: ''\ncategory: ''\norder: 0\n---\n\n# " . $slug . "\n";
        } else {
            // A translation overlays an existing canonical page; there
            // is nothing to translate otherwise.
            if (null === $store->get($slug)) {
                $fail("no base page '{$slug}' — create it in ja first (`bin/docs new {$slug}`)");
            }
            if ('new' === $command && $existsInLocale) {
                $fail("already exists: {$slug} ({$locale}) (use `bin/docs edit {$slug} --locale {$locale}`)");
            }
            if ('edit' === $command && !$existsInLocale) {
                $fail("no '{$locale}' translation for '{$slug}' (use `bin/docs new {$slug} --locale {$locale}`)");
            }
            // New translation seeds from the canonical source so the
            // translator works in place; an existing one seeds itself.
            $seed = $serialize($existsInLocale ? $served : $store->get($slug));
        }

        $doc = $deserialize($editBuffer($seed, $fileOpt), $slug);
        $store->upsert($doc, $note, $locale);
        $suffix = 'ja' === $locale ? '' : " ({$locale})";
        echo ('new' === $command ? 'created' : 'updated') . ": {$slug}{$suffix} -> {$target}\n";

        break;

    case 'rm':
        $store->migrate();
        $locale = $resolveLocale($rest);
        $force = $hasFlag($rest, 'force');
        $slug = $rest[0] ?? $fail('usage: bin/docs rm <slug> [--locale <code>] [--force]');
        // `--locale ja` (or none) removes the whole page incl. every
        // translation; a non-ja locale removes only that one overlay.
        $whole = 'ja' === $locale;
        if ($whole) {
            if (null === $store->get($slug)) {
                $fail("not found: {$slug}");
            }
            $what = "'{$slug}' (and all translations)";
        } else {
            $served = $store->get($slug, $locale);
            if (null === $served || $served->locale !== $locale) {
                $fail("no '{$locale}' translation for '{$slug}'");
            }
            $what = "'{$slug}' ({$locale} translation)";
        }
        if (!$force) {
            if (!\stream_isatty(\STDIN)) {
                $fail("refusing to delete {$what} non-interactively — pass --force");
            }
            \fwrite(\STDOUT, "delete {$what} from {$target}? [y/N] ");
            $ans = \trim((string) \fgets(\STDIN));
            if (!\in_array(\strtolower($ans), ['y', 'yes'], true)) {
                echo "aborted\n";

                break;
            }
        }
        $store->delete($slug, $whole ? null : $locale);
        echo "deleted: {$what}\n";

        break;

    case 'export':
        $store->migrate();
        $locale = $resolveLocale($rest);
        $dir = $rest[0] ?? $fail('usage: bin/docs export <dir> [--locale <code>]');
        if (!\is_dir($dir) && !\mkdir($dir, 0o775, true) && !\is_dir($dir)) {
            $fail("cannot create directory: {$dir}");
        }
        // Non-ja exports only the slugs that actually have a stored
        // translation — never the ja fallback — so an export/import
        // round-trip can't leak canonical text into a locale.
        $only = 'ja' === $locale ? null : $store->translatedSlugs($locale);
        $n = 0;
        foreach ($store->nav() as $meta) {
            if (null !== $only && !isset($only[$meta->slug])) {
                continue;
            }
            $doc = $store->get($meta->slug, $locale);
            if (null === $doc || $doc->locale !== $locale) {
                continue;
            }
            \file_put_contents(\rtrim($dir, '/') . '/' . $doc->slug . '.md', $serialize($doc));
            ++$n;
        }
        echo "exported {$n} article(s) ({$locale}) -> {$dir}\n";

        break;

    case 'import':
        $store->migrate();
        $locale = $resolveLocale($rest);
        if ([] === $rest) {
            $fail('usage: bin/docs import <file.md> [<file.md>...] [--locale <code>]');
        }
        $n = 0;
        foreach ($rest as $path) {
            $raw = @\file_get_contents($path);
            if (!\is_string($raw)) {
                $fail("cannot read: {$path}");
            }
            $slug = \basename($path, '.md');
            $assertSlug($slug);
            if ('ja' !== $locale && null === $store->get($slug)) {
                $fail("no base page '{$slug}' — import its ja source first");
            }
            $store->upsert($deserialize($raw, $slug), null, $locale);
            ++$n;
            echo "  imported {$slug} ({$locale})\n";
        }
        echo "imported {$n} file(s) ({$locale}) -> {$target}\n";

        break;

    case 'help':
    default:
        echo <<<TXT
            relayer-doc CLI — articles live in the store (no source files)

              bin/docs migrate               create the schema (idempotent)
              bin/docs list                  list articles
              bin/docs new  <slug>           create (opens \$EDITOR)
              bin/docs edit <slug> [--note T] edit existing (opens \$EDITOR)
              bin/docs show <slug>           print the stored article
              bin/docs rm   <slug> [--force] delete
              bin/docs export <dir>          back up every article as <slug>.md
              bin/docs import <file.md>...   upsert from front-matter Markdown

            new/edit: --file <path> (or - for stdin) for non-interactive use;
                      --note <text> records what changed (else auto from diff).
            --locale <code>: every command takes it (default ja). ja is the
              canonical page; any other locale is a translation overlay that
              falls back to ja when absent. allowed: ja, en.
            backend: {$target}
              set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN for the remote store.

            TXT;

        break;
}
