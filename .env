# Relayer reads APP_ENV: `dev` enables on-the-fly PSX compilation,
# request profiling and traceable decorators. Unset (or any other
# value) is treated as production.
APP_ENV=dev

# Set DATABASE_DSN to auto-wire the Db layer. It is passed
# straight to PDO (no %placeholder% expansion), e.g.:
# DATABASE_DSN=mysql:host=127.0.0.1;dbname=app
# DATABASE_USER=app
# DATABASE_PASSWORD=secret
# SQLite needs an ABSOLUTE path — PDO resolves a relative DSN
# path against the process cwd: DATABASE_DSN=sqlite:/srv/app/var/app.db
# Set USEPHP_SNAPSHOT_SECRET in production if any page serializes
# snapshot state (a long random string).

# i18n — TEMPORARILY DISABLED (production rollback 2026-05-19).
# Enabling these on FrankenPHP/Fly made every locale path prefix 404
# and the default locale resolve to en, so the live site went
# English-only with Japanese unreachable (the dev `php -S` server did
# not reproduce it). With APP_LOCALES unset Relayer binds no
# LocaleResolver: Request::locale() is null, App\I18n::normalize()
# yields the canonical 'ja', and every surface serves ja exactly as
# the pre-i18n site (the store/code path is backward compatible; the
# en rows stay dormant in Turso). Re-enable only after the
# FrankenPHP path-prefix + APP_LOCALE wiring is diagnosed and fixed.
# APP_LOCALE=ja
# APP_LOCALES=ja,en
# LOCALE_COOKIE=locale
# LOCALE_PATH_PREFIX=true
