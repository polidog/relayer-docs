# Relayer reads APP_ENV: `dev` enables on-the-fly PSX compilation,
# request profiling and traceable decorators. Unset (or any other
# value) is treated as production.
APP_ENV=dev

# Set DATABASE_DSN to auto-wire the Db layer. It is passed
# straight to PDO (no %placeholder% expansion), e.g.:
# DATABASE_DSN=mysql:host=127.0.0.1;dbname=app
# DATABASE_USER=app
# DATABASE_PASSWORD=secret
# SQLite needs an ABSOLUTE path — PDO resolves a relative DSN
# path against the process cwd: DATABASE_DSN=sqlite:/srv/app/var/app.db
# Set USEPHP_SNAPSHOT_SECRET in production if any page serializes
# snapshot state (a long random string).

# i18n. NOTE: this file is .dockerignore'd, so it configures LOCAL
# dev only — production env comes from fly.toml [env] / Fly secrets
# (see SiteUrl's note on env living in Fly config). Locally this gives
# the full bilingual site (ja canonical + en under /en). Production
# currently sets only APP_LOCALE=ja in fly.toml (single locale, no
# path prefix = byte-identical to the pre-i18n site); APP_LOCALES is
# intentionally NOT set in prod until the FrankenPHP path-prefix
# behavior is diagnosed and the bilingual rollout is re-attempted.
APP_LOCALE=ja
APP_LOCALES=ja,en
LOCALE_COOKIE=locale
LOCALE_PATH_PREFIX=true
