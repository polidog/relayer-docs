# Copy to .env.local (gitignored) and fill in for the remote store.
# Without TURSO_* the app/CLI fall back to a local SQLite file at
# var/docs.db — zero credentials needed for local development.

APP_ENV=dev

# Turso (libSQL) — production document store.
# turso db create relayer-doc
# turso db show relayer-doc --url
# turso db tokens create relayer-doc
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: override the local SQLite path (default: var/docs.db)
# DOCS_DB_PATH=/absolute/path/to/docs.db

# Set in production if any page serializes snapshot state.
# USEPHP_SNAPSHOT_SECRET=
